# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/.hf_cache/

# IDE / editor
.cursor/
.idea/
.vscode/
*.log

# testing
coverage/
.coverage

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!backend/.env.example
!frontend/.env.example

# generated media artifacts
test-case/*.mp4
test-case/*.webm
test-case/*.wav

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts
